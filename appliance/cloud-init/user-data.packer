#cloud-config
hostname: ztf-orchestrator-appliance-build
ssh_pwauth: false

users:
  - name: ubuntu
    groups: sudo
    shell: /bin/bash
    sudo: ALL=(ALL) NOPASSWD:ALL
    lock_passwd: true
    ssh_authorized_keys:
      - ${packer_ssh_public_key}

package_update: true
packages:
  - ca-certificates
  - curl
  - git
  - openssl

final_message: "Packer build seed complete."
