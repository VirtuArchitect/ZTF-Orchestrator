# ── ZTF Orchestrator environment variables ────────────────────────────────────
# Copy this file to .env and adjust values for your environment.
# Never commit .env to version control.

# ── Paths ─────────────────────────────────────────────────────────────────────

# Directory for persistent data: users.json, history.json, settings.json, configs/
# Default: ~/.ztf-ui  (or /var/lib/ztf-orchestrator in Docker)
ZTF_DATA_DIR=/var/lib/ztf-orchestrator

# Path to the cloned zerotouch-framework directory
ZTF_PATH=/opt/zerotouch-framework

# Python executable to use when running ZTF
ZTF_PYTHON=/usr/bin/python3

# ── Network ───────────────────────────────────────────────────────────────────

# Port Flask listens on (always bound to 127.0.0.1)
ZTF_PORT=5001

# ── Security ──────────────────────────────────────────────────────────────────

# Session token TTL in seconds (default: 28800 = 8 hours)
ZTF_TOKEN_TTL=28800

# Maximum request body size in bytes (default: 1048576 = 1 MB)
ZTF_MAX_BODY=1048576

# Number of config file backups to retain before overwriting
ZTF_CONFIG_BACKUPS=5

# Storage backend: postgres or file.
# Docker defaults to postgres. Use docker-compose.file.yml for file mode.
ZTF_STORAGE_BACKEND=postgres

# Required when ZTF_STORAGE_BACKEND=postgres.
ZTF_DATABASE_URL=postgresql://ztf:ztf@postgres:5432/ztf_orchestrator

# Default bundled PostgreSQL password. Change before production use.
POSTGRES_PASSWORD=ztf

# Retention windows for database-backed operational history.
ZTF_AUDIT_RETENTION_DAYS=90
ZTF_EXECUTION_RETENTION_DAYS=180

# ── Execution ─────────────────────────────────────────────────────────────────

# Maximum ZTF execution time in seconds before the process is killed
# Default: 3600 (1 hour)
ZTF_EXEC_TIMEOUT=3600

# ── Logging ───────────────────────────────────────────────────────────────────

# Log level: DEBUG, INFO, WARNING, ERROR
ZTF_LOG_LEVEL=INFO

# ── Docker only ───────────────────────────────────────────────────────────────

# Host path to the zerotouch-framework clone (mounted read-only into the container)
ZTF_FRAMEWORK_PATH=/opt/zerotouch-framework
