# ── ZTF Orchestrator environment variables ────────────────────────────────────
# Copy this file to .env and adjust values for your environment.
# Never commit .env to version control.

# ── Paths ─────────────────────────────────────────────────────────────────────

# Directory for persistent data: users.json, history.json, settings.json, configs/
# Default: ~/.ztf-ui  (or /var/lib/ztf-orchestrator in Docker)
ZTF_DATA_DIR=/var/lib/ztf-orchestrator

# Path to the cloned zerotouch-framework directory
ZTF_PATH=/opt/zerotouch-framework

# Path to the cloned NKP ZeroTouch Framework directory
ZTF_NKP_PATH=/var/lib/ztf-orchestrator/nkp-zerotouch-framework

# Python executable to use when running ZTF
ZTF_PYTHON=/usr/bin/python3

# ZeroTouch Framework branch/tag used by Docker and installer paths.
# Keep this on ZTF 1.x for the current workflow/script launcher; ZTF 2.x uses
# a different ztf plan/apply CLI and is detected as incompatible by this release.
ZTF_REF=v1.5.2

# ── Network ───────────────────────────────────────────────────────────────────

# Port Flask listens on.
ZTF_PORT=5001

# Flask bind address. Use 127.0.0.1 for manual/local runs. Docker Compose
# sets this to 0.0.0.0 inside the container and publishes only 127.0.0.1:5001.
ZTF_BIND_HOST=127.0.0.1

# ── Security ──────────────────────────────────────────────────────────────────

# Session token TTL in seconds (default: 28800 = 8 hours)
ZTF_TOKEN_TTL=28800

# Maximum request body size in bytes (default: 1048576 = 1 MB)
ZTF_MAX_BODY=1048576

# Number of config file backups to retain before overwriting
ZTF_CONFIG_BACKUPS=5

# Number of background execution workers
ZTF_EXEC_WORKERS=1

# Storage backend: postgres or file.
# Docker defaults to postgres. Use docker-compose.file.yml for file mode.
ZTF_STORAGE_BACKEND=postgres

# Required when ZTF_STORAGE_BACKEND=postgres. Match POSTGRES_PASSWORD below.
ZTF_DATABASE_URL=postgresql://ztf:change-this-postgres-password@postgres:5432/ztf_orchestrator

# Required by docker-compose.yml. Change before first start.
POSTGRES_PASSWORD=change-this-postgres-password

# Webhooks require https by default and block private/internal destinations.
# Comma-separated host allowlist, for example hooks.example.com,events.company.net.
ZTF_WEBHOOK_ALLOWED_HOSTS=

# Lab-only escape hatch to allow http webhook URLs.
ZTF_WEBHOOK_ALLOW_INSECURE=false

# Retention windows for database-backed operational history.
ZTF_AUDIT_RETENTION_DAYS=90
ZTF_EXECUTION_RETENTION_DAYS=180

# ── Execution ─────────────────────────────────────────────────────────────────

# Maximum ZTF execution time in seconds before the process is killed
# Default: 3600 (1 hour)
ZTF_EXEC_TIMEOUT=3600

# Maximum PostgreSQL backup runtime in seconds before pg_dump is stopped.
ZTF_BACKUP_TIMEOUT=300

# Maximum NKP binary upload size in bytes. Large production bundles should be
# staged on the VM/appliance and registered by path instead.
ZTF_NKP_BINARY_MAX_UPLOAD=536870912

# ── Logging ───────────────────────────────────────────────────────────────────

# Log level: DEBUG, INFO, WARNING, ERROR
ZTF_LOG_LEVEL=INFO

# ── Docker only ───────────────────────────────────────────────────────────────

# Host path to the zerotouch-framework clone (mounted read-only into the container)
ZTF_FRAMEWORK_PATH=/opt/zerotouch-framework
