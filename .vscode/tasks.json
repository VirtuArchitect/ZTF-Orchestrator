{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Python: install requirements",
      "type": "shell",
      "command": ".\\venv\\Scripts\\python.exe -m pip install -r requirements.txt",
      "problemMatcher": []
    },
    {
      "label": "Python: pytest",
      "type": "shell",
      "command": ".\\venv\\Scripts\\python.exe -m pytest",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "Python: pytest current file",
      "type": "shell",
      "command": ".\\venv\\Scripts\\python.exe -m pytest \"${file}\"",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "Frontend: install",
      "type": "shell",
      "command": "npm install",
      "problemMatcher": []
    },
    {
      "label": "Frontend: dev server",
      "type": "npm",
      "script": "dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^(.*)$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "Local:"
        }
      }
    },
    {
      "label": "Frontend: build",
      "type": "npm",
      "script": "build",
      "group": "build",
      "problemMatcher": "$tsc"
    },
    {
      "label": "Quality: backend tests + frontend build",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Python: pytest",
        "Frontend: build"
      ],
      "problemMatcher": []
    }
  ]
}

